{
  "manifest_version": 3,
  "name": "Python To-Do List",
  "version": "1.0",
  "description": "A simple To-Do List extension built with PyScript.",
  "action": {
    "default_popup": "interface.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
